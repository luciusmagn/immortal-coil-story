(in-package #:immortal-coil)

;;; ----------------------------------------------------------------------------
;;; Tiles for the Kenney 1-bit atlas: assets/tiles/kenney-1bit-mono.png, a
;;; 48-column x 22-row grid of 16x16 tiles (col 0..47, row 0..21).
;;;
;;; TWO tables:
;;;   *jrpg-tile-roles*  - what the renderer actually draws. I keep these
;;;                        pointing at the best tiles; I will rewire them from
;;;                        your answers in the catalog below.
;;;   *jrpg-tile-map*    - the full catalog, one entry per tile: (COL ROW "?").
;;;                        Fill the string with what the tile is. Open
;;;                        assets/tiles/atlas-reference.png to read coordinates
;;;                        (column across the top, row down the left). "(blank)"
;;;                        marks an empty cell - skip those.
;;;
;;; The game reads these live; restart the game to see edits.
;;; ----------------------------------------------------------------------------

(defparameter *jrpg-tile-roles*
  ;; role         col row   (real tiles, identified in the Scene Builder)
  '((:floor         8  1)   ; faint street ground
    (:wall          6 13)   ; brick wall
    (:wall-top      6 12)   ; old roof, middle (default; edges use the L/R pieces)
    (:roof-left     5 12)
    (:roof-middle   6 12)
    (:roof-right    7 12)
    (:window        5 13)   ; brick wall with a window
    (:doorway       4 13)   ; brick wall entrance / door
    (:gate         39  4)   ; tall double door (the rim exit)
    (:player       29  9)))

(defun jrpg-tile-coords (role)
  "Return (values col row) for ROLE from *jrpg-tile-roles*; (0 0) if unset."
  (let ((entry (assoc role *jrpg-tile-roles*)))
    (if entry
        (values (second entry) (third entry))
        (values 0 0))))

